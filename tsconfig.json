{
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true,

    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "types": ["node"],

    "strict": true,
    "strictNullChecks": true,
    "tsBuildInfoFile": "node_modules/.tmp/.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "rolldown.config.ts"]
}
