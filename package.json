{
  "name": "setup-protoc",
  "version": "0.0.0",
  "private": true,
  "description": "A GitHub Action workflow for setting up protoc",
  "license": "MIT OR Apache-2.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
